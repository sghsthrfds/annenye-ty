<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Admin Paneli</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .bakim-alani {
            background: #fff3cd;
            border: 1px solid #ffeeba;
            padding: 15px;
            border-radius: 5px;
            margin-bottom: 20px;
        }
        .durum-aktif { color: red; font-weight: bold; }
        .durum-kapali { color: green; font-weight: bold; }
    </style>
</head>
<body>
    <h1>Admin Yönetim Paneli</h1>
    <a href="/admin/cikis" style="float: right;">Güvenli Çıkış</a>
    
    <!-- BAKIM MODU KONTROLÜ -->
    <div class="bakim-alani">
        <h3>Site Bakım Modu Ayarı</h3>
        <p>Mevcut Durum: 
            <% if (bakimAktif === 1) { %>
                <span class="durum-aktif">AKTİF (Kullanıcılar siteye giremez)</span>
            <% } else { %>
                <span class="durum-kapali">KAPALI (Site herkese açık)</span>
            <% } %>
        </p>
        <form action="/admin/bakim-degistir" method="POST">
            <% if (bakimAktif === 1) { %>
                <input type="hidden" name="bakimDurumu" value="pasif">
                <button type="submit" style="background: green; color: white; padding: 8px 15px; border: none; cursor: pointer; border-radius: 4px;">Bakım Modunu Kapat (Sitiyi Aç)</button>
            <% } else { %>
                <input type="hidden" name="bakimDurumu" value="aktif">
                <button type="submit" style="background: red; color: white; padding: 8px 15px; border: none; cursor: pointer; border-radius: 4px;">Bakım Modunu Aktif Et (Hard Kilit)</button>
            <% } %>
        </form>
    </div>

    <hr>
    
    <h2>Yeni Oyun Ekle</h2>
    <form action="/admin/ekle" method="POST">
        <input type="text" name="isim" placeholder="Oyun Adı" required><br><br>
        <input type="text" name="boyut" placeholder="Boyut (Örn: 1.5 GB)" required><br><br>
        <input type="url" name="link" placeholder="Doğrudan İndirme Linki" required><br><br>
        <button type="submit">Oyunu Sisteme Ekle</button>
    </form>

    <h2>Oyunlar ve İndirme İstatistikleri</h2>
    <table border="1" cellpadding="10">
        <thead>
            <tr>
                <th>Oyun Adı</th>
                <th>Boyut</th>
                <th>İndirme Sayısı (Tıklama)</th>
            </tr>
        </thead>
        <tbody>
            <% oyunlar.forEach(oyun => { %>
                <tr>
                    <td><%= oyun.isim %></td>
                    <td><%= oyun.boyut %></td>
                    <td><strong><%= oyun.indirme_sayisi %></strong> kez indirildi</td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>
